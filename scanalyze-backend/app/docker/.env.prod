# ─────────────────────────────────────────────
#  .env.prod  –  PRODUCTION environment
#  ALL values marked CHANGE_ME must come from your secrets manager
#  (AWS Secrets Manager, Vault, Docker Secrets, CI/CD env vars).
#  NEVER commit real prod secrets to git.
# ─────────────────────────────────────────────

APP_ENV=prod
DEBUG=false
LOG_LEVEL=warning

# ── API ──────────────────────────────────────
API_PORT=8000
SECRET_KEY=CHANGE_ME_PROD_SECRET_MIN_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=1
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Database ─────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vision_ai
POSTGRES_USER=vision
POSTGRES_PASSWORD=CHANGE_ME_PROD_DB_PASS
DATABASE_URL=postgresql+asyncpg://vision:CHANGE_ME_PROD_DB_PASS@postgres:5432/vision_ai

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_PROD_REDIS_PASS
REDIS_DB=0
REDIS_URL=redis://:CHANGE_ME_PROD_REDIS_PASS@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_PROD_REDIS_PASS@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_PROD_REDIS_PASS@redis:6379/2

# ── Celery ────────────────────────────────────
CELERY_LOG_LEVEL=warning
CELERY_CONCURRENCY=4

# ── Ollama ────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=300

# ── Object Storage (real S3 in prod) ──────────
S3_ENDPOINT_URL=                          # leave empty to use real AWS S3
S3_ACCESS_KEY=CHANGE_ME_AWS_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_AWS_SECRET_KEY
S3_BUCKET_UPLOADS=vision-uploads-prod
S3_BUCKET_RESULTS=vision-results-prod
S3_REGION=eu-west-1

# ── Email ─────────────────────────────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=noreply@yourdomain.com

# ── Monitoring ────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME
GRAFANA_PASSWORD=CHANGE_ME
DOMAIN=yourdomain.com

# ── Sentry ─────────────────────────────────────
SENTRY_DSN=https://your-prod-sentry-dsn@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.01

# ── Rate limiting (stricter in prod) ──────────
RATE_LIMIT_PER_MINUTE=30
