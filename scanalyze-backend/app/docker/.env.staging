# ─────────────────────────────────────────────
#  .env.staging  –  STAGING environment
#  Values here are examples — override via CI/CD secrets.
# ─────────────────────────────────────────────

APP_ENV=staging
DEBUG=false
LOG_LEVEL=info

# ── API ──────────────────────────────────────
API_PORT=8000
SECRET_KEY=CHANGE_ME_STAGING_32_CHARS_MIN
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=3
ALLOWED_ORIGINS=https://staging.yourdomain.com

# ── Database ─────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vision_ai_staging
POSTGRES_USER=vision
POSTGRES_PASSWORD=CHANGE_ME_STAGING_DB_PASS
DATABASE_URL=postgresql+asyncpg://vision:CHANGE_ME_STAGING_DB_PASS@postgres:5432/vision_ai_staging

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASS
REDIS_DB=0
REDIS_URL=redis://:CHANGE_ME_REDIS_PASS@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASS@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASS@redis:6379/2

# ── Celery ────────────────────────────────────
CELERY_LOG_LEVEL=info
CELERY_CONCURRENCY=2

# ── Ollama ────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=180

# ── Object Storage ────────────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET_UPLOADS=vision-uploads-staging
S3_BUCKET_RESULTS=vision-results-staging
S3_REGION=us-east-1

# ── Email ─────────────────────────────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=staging@yourdomain.com
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=staging@yourdomain.com

# ── Monitoring ────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_FLOWER_PASS
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASS
DOMAIN=staging.yourdomain.com

# ── Sentry ─────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.2

# ── Rate limiting ─────────────────────────────
RATE_LIMIT_PER_MINUTE=60
