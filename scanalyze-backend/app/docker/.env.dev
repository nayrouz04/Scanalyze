# ─────────────────────────────────────────────
#  .env.dev  –  DEVELOPMENT environment
#  Copy to .env.dev and edit. Never commit secrets.
# ─────────────────────────────────────────────

APP_ENV=dev
DEBUG=true
LOG_LEVEL=debug

# ── API ──────────────────────────────────────
API_PORT=8000
SECRET_KEY=dev-secret-key-change-in-prod-must-be-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ─────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vision_ai_dev
POSTGRES_USER=vision
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql+asyncpg://vision:devpassword@postgres:5432/vision_ai_dev

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Celery ────────────────────────────────────
CELERY_LOG_LEVEL=debug
CELERY_CONCURRENCY=1

# ── Ollama ────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# ── Object Storage (MinIO dev) ────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_UPLOADS=vision-uploads
S3_BUCKET_RESULTS=vision-results
S3_REGION=us-east-1

# ── Email (Mailpit local catcher) ─────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=dev@vision-ai.local

# ── Monitoring ────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin
FLOWER_PORT=5555

# ── Sentry (optional) ─────────────────────────
SENTRY_DSN=

# ── Rate limiting ─────────────────────────────
RATE_LIMIT_PER_MINUTE=120
